{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automergeSchedule": [
    "after 5am every weekday",
    "before 4pm every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Budapest",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true
    }
  ],
  "platformAutomerge": true,
  "docker": {
    "enabled": true,
    "fileMatch": [
      "Dockerfile$"    ]
  }
}
